{
  "manifest_version": 3,
  "name": "Coursera Copy Extension",
  "version": "1.2.0",
  "description": "Copy Coursera transcripts, quizzes, readings, and video links to clipboard in [title]\\n<content> format.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*.coursera.org/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Copy Coursera content (Ctrl+Shift+Y)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.coursera.org/*"],
      "js": ["extract.js", "storage.js", "drag.js", "ui.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Copy current Coursera content"
    }
  }
}
